# =============================================
# Modern Signal Advisory — Environment Config
# =============================================
# Copy this to .env.local and fill in values.
# Required variables are marked [REQUIRED].
# Optional variables have defaults shown.

# ─────────────────────────────────────────────
# Database [REQUIRED]
# ─────────────────────────────────────────────
# Supabase PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ─────────────────────────────────────────────
# Authentication — Supabase Auth [REQUIRED]
# ─────────────────────────────────────────────
# These come from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (optional, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# AI / Anthropic [REQUIRED]
# ─────────────────────────────────────────────
# Claude API key for the agent pipeline
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Data APIs [REQUIRED]
# ─────────────────────────────────────────────
# RealEstateAPI — property search, detail, comps, valuations
# Get from https://developer.realestateapi.com
REALESTATEAPI_KEY=

# ScrapingDog — web scraping for neighborhood intelligence
# Get from https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=

# ─────────────────────────────────────────────
# File Storage (Optional — needed for PDF export)
# ─────────────────────────────────────────────
# S3-compatible storage for report PDFs and images
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# SDD Automation (for build scripts only)
# ─────────────────────────────────────────────
CLI_PROVIDER=claude
MAX_FEATURES=50
MAX_RETRIES=3
BRANCH_STRATEGY=chained
DRIFT_CHECK=true
MAX_DRIFT_RETRIES=2
POST_BUILD_STEPS="test"
