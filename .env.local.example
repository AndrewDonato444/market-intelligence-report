# =============================================
# Modern Signal Advisory — Environment Config
# =============================================
# Copy this to .env.local and fill in values.
# Required variables are marked [REQUIRED].
# Optional variables have defaults shown.

# ─────────────────────────────────────────────
# Database [REQUIRED]
# ─────────────────────────────────────────────
# Supabase PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ─────────────────────────────────────────────
# Authentication — Clerk [REQUIRED]
# ─────────────────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Auth route configuration (defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─────────────────────────────────────────────
# AI / Anthropic [REQUIRED]
# ─────────────────────────────────────────────
# Claude API key for the agent pipeline
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Data APIs [REQUIRED]
# ─────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) API key
# Get from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ─────────────────────────────────────────────
# File Storage (Optional — needed for PDF export)
# ─────────────────────────────────────────────
# S3-compatible storage for report PDFs and images
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# SDD Automation (for build scripts only)
# ─────────────────────────────────────────────
CLI_PROVIDER=claude
MAX_FEATURES=50
MAX_RETRIES=3
BRANCH_STRATEGY=chained
DRIFT_CHECK=true
MAX_DRIFT_RETRIES=2
POST_BUILD_STEPS="test"
