{
  "name": "market-intelligence-report",
  "version": "1.0.0",
  "description": "A framework for AI-assisted development that combines: - **Spec-Driven Development (SDD)** - Define behavior before implementing - **User Personas** - Specs are written in users' language, scoped to their patience - **Personality-Driven Design** - Design system derived from vision, not generic templates - **Compound Learning** - Agent gets smarter from every session - **Roadmap-Driven Automation** - Build entire apps feature-by-feature - **Overnight Automation** - Wake up to draft PRs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:pipeline": "tsx --tsconfig tsconfig.json scripts/test-pipeline.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:new-migration": "supabase migration new",
    "db:gen-types": "supabase gen types typescript --local 2>/dev/null > lib/types/database.ts",
    "db:validate": "npm run db:reset && npm run db:gen-types && echo 'Validation complete'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewDonato444/market-intelligence-report.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AndrewDonato444/market-intelligence-report/issues"
  },
  "homepage": "https://github.com/AndrewDonato444/market-intelligence-report#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.4.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0"
  }
}
